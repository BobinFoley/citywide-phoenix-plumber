---
// Inline SVG icon set. Usage: <Icon name="phone" size={18} />
const { name, size = 20, sw = 2 } = Astro.props;
---
{name === 'star' ? (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="m12 2 3 6.3 6.9 1-5 4.9 1.2 6.8L12 18l-6.1 3 1.2-6.8-5-4.9 6.9-1L12 2Z"/></svg>
) : (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={sw} stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    {name === 'logo' && <path d="M12 2.7s6 6.2 6 11a6 6 0 0 1-12 0c0-4.8 6-11 6-11Z" />}
    {name === 'drop' && (<><path d="M12 3s5 5.5 5 9a5 5 0 0 1-10 0c0-3.5 5-9 5-9Z" /><path d="M9.5 21h5" /></>)}
    {name === 'phone' && <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.7A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.2a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.7 2Z" />}
    {name === 'check' && <path d="M20 6 9 17l-5-5" />}
    {name === 'menu' && <path d="M3 6h18M3 12h18M3 18h18" />}
    {name === 'mail' && (<><rect x="3" y="5" width="18" height="14" rx="2" /><path d="m3 7 9 6 9-6" /></>)}
    {name === 'clock' && (<><circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 2" /></>)}
    {name === 'shield' && <path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5l-8-3Z" />}
    {name === 'shield-check' && (<><path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5l-8-3Z" /><path d="m9 12 2 2 4-4" /></>)}
    {name === 'bolt' && <path d="M13 2 3 14h7l-1 8 10-12h-7l1-8Z" />}
    {name === 'pin' && (<><path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 0 1 18 0Z" /><circle cx="12" cy="10" r="3" /></>)}
    {name === 'dollar' && <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />}
    {name === 'drain' && (<><path d="M3 7h7v3a4 4 0 0 0 8 0V7h3" /><path d="M7 7V4M7 21v-7" /><circle cx="7" cy="17.5" r="3.5" /></>)}
    {name === 'heater' && (<><rect x="6" y="3" width="12" height="18" rx="3" /><path d="M9 7h6M10 12c0 1.5 4 1.5 4 0s-2-2-2-3.5" /></>)}
  </svg>
)}
